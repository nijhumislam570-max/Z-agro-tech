VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SITE_URL="https://your-domain.example"
VITE_SENTRY_DSN="https://public-key@o0.ingest.us.sentry.io/project-id"
VITE_SENTRY_ENVIRONMENT="production"
VITE_SENTRY_RELEASE="z-agro-tech@1.0.0"
VITE_SENTRY_TRACES_SAMPLE_RATE="0.2"

# Build-time source map upload for the Vite Sentry plugin.
# Keep these out of git by placing them in local env only.
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
SENTRY_ORG="zagrotech"
SENTRY_PROJECT="your-frontend-project-slug"
SENTRY_RELEASE="z-agro-tech@1.0.0"
